{
  "name": "dorixona-backend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "description": "Pharmacy management backend built with Fastify, TypeScript, and Prisma.",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:start": "pg_ctl -D /opt/homebrew/var/postgresql@14 -o \"-p 5433\" -l /tmp/postgresql@14-dorixona.log start",
    "db:stop": "pg_ctl -D /opt/homebrew/var/postgresql@14 stop",
    "db:status": "pg_isready -h localhost -p 5433",
    "db:setup": "createdb -h localhost -p 5433 dorixona_db || true && prisma migrate deploy && prisma generate && prisma db seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.0.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "^6.7.0",
    "argon2": "^0.41.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "google-auth-library": "^9.15.1",
    "nodemailer": "^6.10.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "prisma": "^6.7.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
