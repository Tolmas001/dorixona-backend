generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  SELLER
  CUSTOMER
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIAL
}

enum OnlineOrderStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  username      String     @unique @db.VarChar(50)
  email         String     @unique @db.VarChar(255)
  password      String?    @db.VarChar(255)
  full_name     String     @db.VarChar(150)
  tel_number    String     @db.VarChar(30)
  delivery_address String? @db.Text
  age           Int
  is_email_verified Boolean @default(false)
  isBlocked     Boolean    @default(false)
  role          Role       @default(CUSTOMER)
  pharmacy_id   String?    @db.Uuid
  google_id     String?    @unique @db.VarChar(255)
  refresh_token_hash String? @db.VarChar(255)
  pharmacy      Pharmacy?  @relation(fields: [pharmacy_id], references: [id], onDelete: SetNull)
  sales         Sale[]     @relation("SellerSales")
  onlineOrders  OnlineOrder[]
  auditLogs     AuditLog[] @relation("AuditActor")
  emailOtps     EmailOtp[]
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @updatedAt @db.Timestamptz(6)

  @@index([username])
  @@index([pharmacy_id])
  @@map("users")
}

model EmailOtp {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  codeHash    String   @db.VarChar(255)
  expiresAt   DateTime @db.Timestamptz(6)
  consumedAt  DateTime? @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_otps")
}

model Pharmacy {
  id            String     @id @default(uuid()) @db.Uuid
  name          String     @db.VarChar(200)
  licenseNumber String     @unique @db.VarChar(100)
  address       String?    @db.Text
  phone         String?    @db.VarChar(30)
  isBlocked     Boolean    @default(false)
  archivedAt    DateTime?  @db.Timestamptz(6)
  users         User[]
  stocks        Stock[]
  sales         Sale[]
  onlineOrders  OnlineOrder[]
  subscriptions PharmacySubscription[]
  auditLogs     AuditLog[]
  createdAt     DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @db.Timestamptz(6)

  @@map("pharmacies")
}

model Product {
  id            String     @id @default(uuid()) @db.Uuid
  name          String     @db.VarChar(200)
  sku           String?    @unique @db.VarChar(100)
  barcode       String     @unique @db.VarChar(100)
  imageUrl      String?    @db.VarChar(500)
  purchasePrice Decimal    @db.Decimal(12, 2)
  sellingPrice  Decimal    @db.Decimal(12, 2)
  expiryDate    DateTime   @db.Date
  manufacturer  String?    @db.VarChar(200)
  stocks        Stock[]
  saleItems     SaleItem[]
  createdAt     DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @db.Timestamptz(6)

  @@index([name])
  @@index([barcode])
  @@index([expiryDate])
  @@map("products")
}

model Stock {
  id            String     @id @default(uuid()) @db.Uuid
  pharmacyId    String     @db.Uuid
  productId     String     @db.Uuid
  batchNumber   String     @db.VarChar(100)
  quantity      Int        @default(0)
  reorderLevel  Int        @default(0)
  expiryDate    DateTime   @db.Date
  pharmacy      Pharmacy   @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @db.Timestamptz(6)

  @@unique([pharmacyId, productId, batchNumber])
  @@index([productId])
  @@index([expiryDate])
  @@map("stocks")
}

model Sale {
  id            String      @id @default(uuid()) @db.Uuid
  pharmacyId    String      @db.Uuid
  sellerId      String      @db.Uuid
  soldAt        DateTime    @default(now()) @db.Timestamptz(6)
  totalAmount   Decimal     @db.Decimal(12, 2)
  paymentType   String      @default("Naqd") @db.VarChar(40)
  discountPercent Decimal   @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal   @default(0) @db.Decimal(12, 2)
  notes         String?     @db.Text
  pharmacy      Pharmacy    @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  seller        User        @relation("SellerSales", fields: [sellerId], references: [id], onDelete: Restrict)
  items         SaleItem[]
  onlineOrders  OnlineOrder[]
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)

  @@index([pharmacyId])
  @@index([sellerId])
  @@index([soldAt])
  @@map("sales")
}

model OnlineOrder {
  id              String            @id @default(uuid()) @db.Uuid
  pharmacyId      String?           @db.Uuid
  customerId      String?           @db.Uuid
  customerName    String            @db.VarChar(150)
  customerPhone   String?           @db.VarChar(30)
  status          OnlineOrderStatus @default(PENDING)
  totalAmount     Decimal           @db.Decimal(12, 2)
  items           Json
  approvedSaleId  String?           @db.Uuid
  rejectedReason  String?           @db.Text
  pharmacy        Pharmacy?         @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)
  customer        User?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  approvedSale    Sale?             @relation(fields: [approvedSaleId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @db.Timestamptz(6)

  @@index([pharmacyId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("online_orders")
}

model SaleItem {
  id            String     @id @default(uuid()) @db.Uuid
  saleId        String     @db.Uuid
  productId     String     @db.Uuid
  quantity      Int
  unitPrice     Decimal    @db.Decimal(12, 2)
  lineTotal     Decimal    @db.Decimal(12, 2)
  sale          Sale       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product       Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model BillingPlan {
  id              String                 @id @default(uuid()) @db.Uuid
  name            String                 @unique @db.VarChar(120)
  code            String                 @unique @db.VarChar(60)
  description     String?                @db.Text
  price           Decimal                @db.Decimal(12, 2)
  billingInterval BillingInterval
  maxUsers        Int?
  maxPharmacies   Int?
  isActive        Boolean                @default(true)
  subscriptions   PharmacySubscription[]
  createdAt       DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime               @updatedAt @db.Timestamptz(6)

  @@map("billing_plans")
}

model PharmacySubscription {
  id          String             @id @default(uuid()) @db.Uuid
  pharmacyId  String             @db.Uuid
  planId      String             @db.Uuid
  status      SubscriptionStatus @default(ACTIVE)
  startsAt    DateTime           @default(now()) @db.Timestamptz(6)
  endsAt      DateTime?          @db.Timestamptz(6)
  autoRenew   Boolean            @default(true)
  pharmacy    Pharmacy           @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  plan        BillingPlan        @relation(fields: [planId], references: [id], onDelete: Restrict)
  createdAt   DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @db.Timestamptz(6)

  @@index([pharmacyId])
  @@index([planId])
  @@map("pharmacy_subscriptions")
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  actorId     String?   @db.Uuid
  pharmacyId  String?   @db.Uuid
  action      String    @db.VarChar(120)
  entityType  String    @db.VarChar(120)
  entityId    String?   @db.VarChar(120)
  metadata    Json?
  actor       User?     @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  pharmacy    Pharmacy? @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)

  @@index([actorId])
  @@index([pharmacyId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Advertisement {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(160)
  text        String?  @db.Text
  imageUrl    String?  @db.VarChar(500)
  targetUrl   String?  @db.VarChar(500)
  placement   String   @default("HOME_HERO") @db.VarChar(80)
  isActive    Boolean  @default(true)
  viewCount   Int      @default(0)
  clickCount  Int      @default(0)
  startsAt    DateTime? @db.Timestamptz(6)
  endsAt      DateTime? @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@index([placement])
  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
  @@map("advertisements")
}

model PlatformSetting {
  key       String   @id @db.VarChar(120)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("platform_settings")
}
